generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(50) // e.g., "ADMIN", "CS"
  permissions Json     // JSON mapping: { "dashboard": "read", "leads": "write", ... }
  admins      Admin[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Admin {
  id          Int      @id @default(autoincrement())
  nama_admin  String   @db.VarChar(100)
  nomor_wa    String?  @unique @db.VarChar(20)
  username    String   @unique @db.VarChar(50)
  password    String   @db.VarChar(255)
  role_id     Int      @default(1)
  role        Role     @relation(fields: [role_id], references: [id])
  is_active   Boolean  @default(true)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Customer {
  id          Int      @id @default(autoincrement())
  nomor_hp    String   @unique @db.VarChar(20)
  nama_kontak String?  @db.VarChar(100)
  is_ignored  Boolean  @default(false)
  leads       Lead[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lead {
  id                           Int           @id @default(autoincrement())
  kode_lead                    String        @unique @db.VarChar(50)
  customer_id                  Int
  customer                     Customer      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  admin_id                     Int
  admin                        Admin         @relation(fields: [admin_id], references: [id])
  
  status_lead                  String        @default("NEW") 
  minat_destinasi              String?       @db.VarChar(255)
  jumlah_peserta               Int?
  estimasi_waktu               DateTime?
  catatan_khusus               String?       @db.Text
  catatan_sistem               String?       @db.Text
  referral_source              String        @default("tidak diketahui") @db.VarChar(50)
  estimasi_nilai_order         Int?

  // Asynchronous AI Queue tracking fields
  last_activity_at             DateTime?
  closed_at                    DateTime?
  ai_summary                   String?       @db.Text
  ai_last_analyzed_message_id  Int?
  ai_last_analyzed_at          DateTime?
  
  messages                     ChatMessage[]
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @updatedAt

  @@index([status_lead])
  @@index([updatedAt])
}

model ChatMessage {
  id              Int      @id @default(autoincrement())
  wa_message_id   String?  @unique @db.VarChar(100)
  lead_id         Int
  lead            Lead     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  pengirim        String   @db.VarChar(20) // "admin" atau "customer"
  pesan       String   @db.Text
  waktu_pesan DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([waktu_pesan])
}

model AIJob {
  id          Int       @id @default(autoincrement())
  lead_id     Int
  status      String    @db.VarChar(20) // "WAITING", "PROCESSING", "DONE", "FAILED"
  execute_at  DateTime?
  retry_count Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, execute_at])
}

model AIAnalysis {
  id          Int      @id @default(autoincrement())
  lead_id     Int
  result_json Json
  createdAt   DateTime @default(now())

  @@index([lead_id])
}

model WhatsAppSession {
  id        Int      @id @default(autoincrement())
  admin_id  Int
  key       String   @db.VarChar(255)
  value     String   @db.LongText
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([admin_id, key])
  @@index([admin_id])
}

